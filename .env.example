# ─── Database (Neon) ───────────────────────────────
# Pooled connection — used by the app at runtime.
# Found in Neon Console → Connection Details → Connection string (pooled)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/endexly?sslmode=require

# Direct connection — used by migrations and seed scripts.
# Found in Neon Console → Connection Details → Connection string (direct)
DIRECT_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/endexly?sslmode=require

# ─── Clerk Authentication ─────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Default redirect after sign-in when no redirect_url is present.
# Sends users straight to the admin panel after logging in.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/admin

# ─── Platform Domain Config ──────────────────────
# Root domain used for subdomain parsing and building tenant URLs.
# For local dev: endexly.localhost:3000
# For production: endexly.com (or your custom domain)
NEXT_PUBLIC_ROOT_DOMAIN=endexly.localhost:3000

# ─── Payload CMS ─────────────────────────────────
# A random secret string (min 32 chars) used for JWT token signing.
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=change-me-to-a-random-32-char-string

# Secret token used by Payload's "Preview URL" feature to enable draft mode.
# Generate with: openssl rand -hex 16
PAYLOAD_PREVIEW_SECRET=change-me-to-a-random-preview-secret

# ─── Seed Data ────────────────────────────────────
# Your Clerk user ID for the platform admin seed record.
# Find this in your Clerk dashboard → Users → click your user → copy User ID
SEED_ADMIN_CLERK_USER_ID=user_xxxxxxxxxxxxx

# (Optional) Pre-seed a specific site ID into Payload content.
# Leave blank to auto-resolve from 'acme-website' slug.
# SEED_SITE_ID=
